# Sensitive files — credentials, keys, certs
*.key
*.pem
*.crt
*.csr
*.p12
*.pfx
id_rsa*
id_ed25519*
*kubeconfig*
*admin.conf
.env
.env.*
vault-init.json
secrets/
**/secrets.yaml
**/*secret.yaml
*cloudflare-secret*

# Ansible
# Don't commit actual node IPs in inventory (use inventory.example)
inventory.ini
*.retry
.ansible/

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
**/.DS_Store
Thumbs.db

# Temporary / build
tmp/
*.tmp
*.bak
/tmp/kubeadm-join-command.sh

# Logs
*.log

# Personal docs (not for repo)
CLAUDE.md

# Config (local overrides)
.config/

# Re-include ESO store manifests (not secrets — just ExternalSecret CRs)
!platform/security/external-secrets/stores/
!platform/security/external-secrets/stores/**
